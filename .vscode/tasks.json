{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "devcontainer: Start HA",
      "command": "echo 'Starting Home Assistant' && sh -c 'make run'",
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": false,
          "beginsPattern": ".",
          "endsPattern": ".*Listening for remote debug connection on.*"
        }
      },
      "group": "test",
      "isBackground": true
    },
    {
      "type": "shell",
      "label": "devcontainer: stop debug",
      "command": "echo 'Stopping Home Assistant' && sh -c 'killall /home/vscode/.local/ha-venv/bin/python3'",
      "problemMatcher": []
    }
  ]
}
